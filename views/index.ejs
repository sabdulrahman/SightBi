      function getBubbleMapData() {
        $.ajax({
          type: "GET",
          url: "http://localhost:3000/getBubbleMapData",
          dataType: "text",
          success: function(data) {
            drawBubbleMap();
            document.querySelector('.bubble-map-button').removeAttribute('disabled');
          },
          error: function(err) {
            console.log(err);
          }
        });
      }

      function checkForBubbleData() {
        $.ajax({
          type: "GET",
          url: "map-data.csv",
          dataType: "text",
          success: function(data) {
            if(data.length === 0) {
              getBubbleMapData();
            } else {
              document.querySelector('.bubble-map-button').removeAttribute('disabled');
            }
          },
          error: function(err) {
            console.log(err);
            getBubbleMapData();
          }
        });
      }


