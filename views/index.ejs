	function organizedata() {
var margin = {top: 30, right: 30, bottom: 70, left: 190},
    width = 700 - margin.left - margin.right,
    height = 550 - margin.top - margin.bottom;
	
	var body = d3.select(".organize-data-box").classed("svg-container", true)
	
    var svg = body.append("svg").attr("preserveAspectRatio", "xMinYMin meet")
									.attr("viewBox", "0 0 700 600").append("g")
        .attr("transform", "translate(" + margin.left + "," + margin.top + ")");

    var x = d3.scaleLinear()
          .range([0, width]);

    var y = d3.scaleBand()
        .range([height, 0]);


    var yAxis = d3.axisLeft(y);

d3.csv("orga.csv", type, function(error, data) {
      if (error) throw error;

data.sort(function(a, b) {
    if(a.organize < b.organize) { return -1; }
    if(a.organize > b.organize) { return 1; }
    return 0;      });
	  
	  
  x.domain([0, d3.max(data, function(d) { return d.Value; }) + 5]);

      y.domain(data.map(function(d) { return d.organize; }))
        .paddingInner(0.1);


      svg.append("g")
          .attr("class", "x axis")
      .attr("transform", "translate(0," + height + ")")
      .call(d3.axisBottom(x));

      svg.append("g")
          .attr("class", "axis axis--y")
          .call(yAxis);

      svg.selectAll(".bar")
          .data(data)
        .enter().append("rect")
          .attr("class", "bar")
          .attr("x", 0)
          .attr("height", y.bandwidth())
          .attr("y", function(d) { return y(d.organize); })
          .attr("width", function(d) { return x(d.Value); })
		  .attr('docId',function(d) {return d.docId})
		  .attr('orgname',function(d) {return d.organize})
		  .attr('barid',function(d,i){return (i);})
		  .attr('freq',function(d) {return d.Value})
		  .style("fill", '#ad9ee3')
		  .style("stroke-width",0.3)
		  .style("stroke",'rgb(0,0,0)')
		  .attr("clickhist",0)
		  .attr('cx',0)
		  .attr('cy',function(d){return y(d.organize);})
		  .on("mouseover", organizehover)
		  .on("mouseout",organizeout)
		  .on("mouseup",organizeclick);


		svg.append("text")
		.attr("text-anchor", "middle")
		.style("font-size", "13px")
		.attr("transform", "translate("+ (width/2) + "," +(height+40) + ")")
		.style("color", "#333333")
		.text("Frequency")
		.style("font-family", "Arial"); 
		
		svg.append("text")
		.attr("text-anchor", "middle")
		.style("font-size", "13px")
		.attr("transform", "translate("+ (width/2) + "," +(height - 470) + ")")
		.style("color", "#333333")
		.text("Organizations")
		.style("font-family", "Arial"); 

$("#sort").on("change", change);

$('.organize-data-box').on('drag', reDrawLines);
$('.organize-data-box').on('resize', reDrawLines);

function change() {
	var yScale0 = y.domain(data.sort(this.checked
		? function(a, b) { return a.Value - b.Value; }
		: function(a, b) { return d3.descending(b.organize, a.organize); })
		.map(function(d) { return d.organize; }))
		.copy();
	svg.selectAll(".bar")
		.sort(function(a, b) { return yScale0(b.organize) - yScale0(a.organize); });
	var transition = svg.transition().duration(750);
	var delay = function(d, i) { return i * 50; };
	transition.selectAll(".bar")
			.delay(delay)
			.attr("y", function(d) { return yScale0(d.organize); });
	transition.select(".axis--y")
		.call(d3.axisLeft(y))
		.selectAll("g")
			.delay(delay);
}
})
}

