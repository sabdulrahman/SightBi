                target : {
                  id: "highlight-text",
				  ele:sid,
                  xOffset : x2Loc,
                  yOffset : y2Loc
                }
              });

              connections1bt.push({ source: ele, sourceid:locid, target: $('#' + sid), targetid:sid, boxElement: 'bubblemap-box' });
              drawPolyLineMap(bubbleToTextCollection);

